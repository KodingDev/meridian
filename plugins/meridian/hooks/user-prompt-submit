#!/usr/bin/env bash
set -euo pipefail

input=$(cat)
session_id=$(printf '%s' "$input" | jq -r '.session_id // empty' 2>/dev/null || true)
[ -z "${session_id:-}" ] && exit 0

state_dir="${PWD}/.meridian/state/${session_id}"
tick_file="${state_dir}/router-tick"
mkdir -p "$state_dir"

tick=0
[ -f "$tick_file" ] && tick=$(cat "$tick_file" 2>/dev/null || echo 0)
case "$tick" in ''|*[!0-9]*) tick=0 ;; esac
tick=$((tick + 1))
printf '%d\n' "$tick" > "$tick_file"

if [ "$tick" -gt 0 ] && [ $((tick % 8)) -eq 0 ]; then
  cat <<'EOF'
[MERIDIAN] Conversation depth check — 8 messages since last router pass.
- What is the active skill (if any)?
- Has the user's intent shifted from the originally-routed work?
- Is there an external-system claim now in scope that should trigger triangulate?
- If shifted or unsure, re-invoke meridian:meridian for a fresh routing pass.

This message is throttled — it will fire again in 8 messages.
EOF
fi
